generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String?
  phone         String?
  storeName     String
  plan          Plan           @default(FREE)
  role          UserRole       @default(USER)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  googleId      String?        @unique(map: "googleId")
  agent         Agent?
  products      Product[]
  services      Service[]
  conversations Conversation[]
  customers     Customer[]
  notifications Notification[]
  appointments  Appointment[]
  orders        Order[]
  invoices      Invoice[]

  @@map("users")
}

model VerificationToken {
  id        String   @id @default(cuid())
  phone     String
  code      String
  data      String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("verification_tokens")
}

model Agent {
  id                String           @id @default(cuid())
  userId            String           @unique
  name              String           @default("Agent")
  domain            String           @default("تجارة عامة")
  style             String           @default("friendly")
  language          String           @default("darija")
  isActive          Boolean          @default(true)
  instructions      String?          @db.Text
  whatsappPhoneId   String?
  whatsappToken     String?          @db.Text
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  selectedProductId String?
  offlineMessage    String?          @db.Text
  postSaleMessage   String?          @db.Text
  welcomeMessage    String?          @db.Text
  workEnd           String           @default("18:00")
  workHoursEnabled  Boolean          @default(false)
  workStart         String           @default("09:00")
  verifyToken       String?          @default(uuid())
  selectedServiceId String?
  mode              String           @default("product")

  // ✅ رسائل المواعيد التلقائية
  appointmentConfirmMessage     String? @db.Text
  appointmentReminderMessage    String? @db.Text
  appointmentCancellationMessage String? @db.Text

  // ✅ رسائل الطلبيات التلقائية
  orderConfirmMessage   String? @db.Text
  orderShipMessage      String? @db.Text
  orderDeliverMessage   String? @db.Text
  orderCancelledMessage String? @db.Text

  // ✅ رابط التتبع من شركة التوصيل (مثال: https://tracking.company.com/?code={tracking})
  trackingUrlTemplate   String? @db.Text

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  objectionReplies  ObjectionReply[]

  @@map("agents")
}

model ObjectionReply {
  id      String @id @default(cuid())
  agentId String
  trigger String
  reply   String @db.Text
  order   Int    @default(0)
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("objection_replies")
}

model Product {
  id          String   @id @default(cuid())
  userId      String
  name        String
  price       Float
  description String?  @db.Text
  isActive    Boolean  @default(true)
  questions   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  images      String?  @db.Text
  stock       Int      @default(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("products")
}

model Service {
  id          String   @id @default(cuid())
  userId      String
  name        String
  price       Float
  duration    Int      @default(60)
  description String?  @db.Text
  images      String?  @db.Text
  isActive    Boolean  @default(true)
  questions   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("services")
}

model Conversation {
  id          String            @id @default(cuid())
  userId      String
  customerId  String
  stage       ConversationStage @default(GREETING)
  score       Int               @default(0)
  isRead      Boolean           @default(false)
  totalAmount Float?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  serviceId   String?
  type        String            @default("product")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer    Customer          @relation(fields: [customerId], references: [id])
  messages    Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Customer {
  id            String         @id @default(cuid())
  userId        String
  name          String
  phone         String
  tag           CustomerTag    @default(NEW)
  totalSpent    Float          @default(0)
  ordersCount   Int            @default(0)
  lastSeen      DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  appointments  Appointment[]
  orders        Order[]

  @@unique([userId, phone])
  @@map("customers")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Appointment {
  id                String            @id @default(cuid())
  userId            String
  customerId        String?
  customerName      String
  customerPhone     String
  serviceId         String?
  serviceName       String
  date              DateTime
  status            AppointmentStatus @default(PENDING)
  notes             String?           @db.Text
  reminderSent      Boolean           @default(false)
  confirmationSent  Boolean           @default(false)
  cancellationSent  Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer          Customer?         @relation(fields: [customerId], references: [id])
  service           Service?          @relation(fields: [serviceId], references: [id])

  @@index([userId, date])
  @@index([userId, status])
  @@map("appointments")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum UserRole {
  USER
  SUPER_ADMIN
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum ConversationStage {
  GREETING
  DISCOVERY
  PITCHING
  OBJECTION
  CLOSING
  CLOSED
  ABANDONED
  ARCHIVED
}

enum MessageRole {
  USER
  AGENT
}

enum CustomerTag {
  NEW
  REGULAR
  VIP
  PROSPECT
}

enum NotificationType {
  NEW_ORDER
  OBJECTION_ALERT
  DAILY_REPORT
  AGENT_DOWN
  SYSTEM
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  customerId     String?
  conversationId String?
  customerName   String
  customerPhone  String
  productId      String?
  productName    String
  quantity       Int         @default(1)
  totalAmount    Float
  status         OrderStatus @default(PENDING)
  address        String?     @db.Text
  notes          String?     @db.Text
  confirmSent    Boolean     @default(false)
  shipSent       Boolean     @default(false)
  deliverSent    Boolean     @default(false)
  trackingNumber String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer       Customer?   @relation(fields: [customerId], references: [id])

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("orders")
}

model Invoice {
  id            String        @id @default(cuid())
  clientId      String
  invoiceNumber String        @unique
  amount        Float
  plan          Plan          @default(FREE)
  status        InvoiceStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  notes         String?       @db.Text
  bankInfo      String?       @db.Text
  whatsappSent  Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  client        User          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@map("invoices")
}
